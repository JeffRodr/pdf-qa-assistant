# Clave de la API de Cohere (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=

# Modelo de chat de Cohere a usar
COHERE_MODEL=command-r-08-2024

# Puerto donde corre el servidor Flask
PORT=5000

# Carpeta donde se buscan los PDFs a indexar
DOCUMENTS_DIR=documents

# Cantidad de fragmentos de contexto a recuperar por pregunta
TOP_K=4
